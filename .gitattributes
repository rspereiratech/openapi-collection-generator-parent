# Normalize line endings on commit; check out using the platform's native style.
* text=auto eol=lf

# Source files — force LF
*.java   text eol=lf
*.xml    text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.properties text eol=lf
*.sh     text eol=lf

# Windows batch files — force CRLF
*.bat    text eol=crlf
*.cmd    text eol=crlf

# Binary files
*.jar    binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.zip    binary
